### ------------------------------------------------------
### PASSO 1-5: LOGIN ASSINANTE + START CHECKOUT DE ASSINATURA
### ------------------------------------------------------
### @name loginStudioSubscriber
POST {{baseUrl}}/auth/signin
Content-Type: application/json

{
  "email": "{{subscriberEmail}}",
  "password": "{{subscriberPassword}}"
}

### @name startCheckout
POST {{baseUrl}}/subscription-checkout/start
Authorization: Bearer {{subscriberToken}}
Content-Type: application/json

{
  "planTier": "PROFESSIONAL",
  "billingCycle": "MONTHLY",
  "studioName": "Rock Valley Studio",
  "domainType": "SUBDOMAIN",
  "subdomain": "{{subdomain}}",
  "paymentMethod": "CARD",
  "totalAmount": 197
}

### ------------------------------------------------------
### PASSO 5.1: CONSULTAR STATUS (PENDING_PAYMENT)
### ------------------------------------------------------

GET {{baseUrl}}/subscription-checkout/{{checkoutId}}
Authorization: Bearer {{subscriberToken}}

### ------------------------------------------------------
### PASSO 6: CONFIRMAR PAGAMENTO (SIMULADO, PROTEGIDO)
### Requer OWNER token
### ------------------------------------------------------
### @name approveCheckout
POST {{baseUrl}}/subscription-checkout/{{checkoutId}}/approve
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "paymentReference": "evt_payment_ok_{{$timestamp}}"
}

### ------------------------------------------------------
### PASSO 7: DASHBOARD LIBERADO (ASSINATURA APROVADA)
### ------------------------------------------------------

### ------------------------------------------------------
### PASSO 8: SETTINGS -> CADASTRAR SALAS
### Para PROFESSIONAL: até 3 salas.
### ------------------------------------------------------
POST {{baseUrl}}/settings/studios/{{studioId}}/rooms
Authorization: Bearer {{subscriberToken}}
Content-Type: application/json

{
  "name": "Sala A - Ensaio",
  "type": "rehearsal",
  "description": "Ideal para bandas e ensaios.",
  "pricePerHour": 80,
  "capacity": 6,
  "features": ["Bateria acústica", "PA 1000W"]
}

### @name createRoomB
### ✅ Criar Sala B
POST {{baseUrl}}/settings/studios/{{studioId}}/rooms
Authorization: Bearer {{subscriberToken}}
Content-Type: application/json

{
  "name": "Sala B - Gravação",
  "type": "recording",
  "description": "Sala para gravações profissionais.",
  "pricePerHour": 150,
  "capacity": 4,
  "features": ["Mesa digital", "Microfones premium"]
}

### @name createRoomC
### ✅ Criar Sala C
POST {{baseUrl}}/settings/studios/{{studioId}}/rooms
Authorization: Bearer {{subscriberToken}}
Content-Type: application/json

{
  "name": "Sala C - Podcast",
  "type": "podcast",
  "description": "Ambiente para podcast.",
  "pricePerHour": 60,
  "capacity": 3,
  "features": ["3 microfones", "Interface de audio"]
}

### ------------------------------------------------------
### EXTRA: VALIDAR LIMITE DE PLANO (4a sala -> 409 no PROFESSIONAL)
### ------------------------------------------------------
POST {{baseUrl}}/settings/studios/{{studioId}}/rooms
Authorization: Bearer {{subscriberToken}}
Content-Type: application/json

{
  "name": "Sala D - Extra",
  "type": "extra",
  "description": "Teste de limite do plano.",
  "pricePerHour": 99,
  "capacity": 5,
  "features": ["Teste limite"]
}
