### ======================================================
### STAGEFLOW - ONBOARDING DE ASSINATURA (CONTRATO)
### ======================================================

@baseUrl = http://localhost:4000
@onboardingId = 33dada2f-ac85-44e1-b8d0-2d792b53d0ea
@ownerToken = REPLACE_OWNER_TOKEN
@studioAdminToken = REPLACE_STUDIO_ADMIN_TOKEN

### @name startOnboarding
### ✅ Iniciar onboarding (plano + dados + domínio + pagamento)
POST {{baseUrl}}/onboarding/start
Content-Type: application/json

{
  "planTier": "PROFESSIONAL",
  "billingCycle": "ANNUAL",
  "studioName": "Rock Valley Studio",
  "ownerName": "Carlos Mendes",
  "ownerEmail": "contato@rockvalley.com.br",
  "ownerPhone": "(11) 99999-9999",
  "ownerDocument": "000.000.000-00",
  "domainType": "SUBDOMAIN",
  "subdomain": "rockvalley",
  "paymentMethod": "CARD",
  "totalAmount": 1970
}

### ✅ Consultar status de onboarding
GET {{baseUrl}}/onboarding/{{onboardingId}}

### ✅ Confirmar onboarding (simula confirmação da etapa financeira)
### @name confirmOnboarding
POST {{baseUrl}}/onboarding/{{onboardingId}}/confirm
Authorization: Bearer {{ownerToken}}
Content-Type: application/json

{
  "paymentReference": "evt_payment_ok_123"
}

### ✅ Adicionar sala via Settings (respeita limite do plano)
POST {{baseUrl}}/settings/studios/{{confirmOnboarding.response.body.onboarding.studioId}}/rooms
Authorization: Bearer {{studioAdminToken}}
Content-Type: application/json

{
  "name": "Sala A - Ensaio",
  "type": "rehearsal",
  "description": "Ideal para bandas e ensaios.",
  "pricePerHour": 80,
  "capacity": 6,
  "features": ["Bateria acústica", "PA 1000W"]
}

### ❌ Confirm sem token OWNER (deve retornar 401/403)
POST {{baseUrl}}/onboarding/{{onboardingId}}/confirm
Content-Type: application/json

{
  "paymentReference": "evt_payment_without_owner"
}

### ❌ Subdomínio indisponível (deve retornar 409)
POST {{baseUrl}}/onboarding/start
Content-Type: application/json

{
  "planTier": "STARTER",
  "billingCycle": "MONTHLY",
  "studioName": "Outro Studio",
  "ownerName": "Ana",
  "ownerEmail": "ana@studio.com",
  "ownerPhone": "(11) 90000-0000",
  "ownerDocument": "111.111.111-11",
  "domainType": "SUBDOMAIN",
  "subdomain": "rockvalley",
  "paymentMethod": "PIX",
  "totalAmount": 80
}
