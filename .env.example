# App
NODE_ENV=development
PORT=4000
JWT_SECRET=change-me

# URLs (obrigatórias para Mercado Pago: BACKEND_URL, FRONTEND_URL)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Assinatura da plataforma: mercadopago (padrão) ou stripe
PLATFORM_SUBSCRIPTION_PROVIDER=mercadopago

# Mercado Pago — assinatura (token da aplicação) + webhooks
MERCADOPAGO_ACCESS_TOKEN=
# Chave pública da mesma aplicação (Checkout Transparente / MP.js — assinatura com cartão)
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET_KEY=
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_OAUTH_REDIRECT_URI=http://localhost:4000/auth/mercadopago/callback
MERCADOPAGO_API_URL=https://api.mercadopago.com
MERCADOPAGO_API_VERSION=v1
MERCADOPAGO_BOLETO_BANK_ID=bolbradesco

# Taxa da plataforma em pagamentos de reserva (OAuth marketplace); 0–100; só aplicada quando o dono conectou via OAuth
MERCADOPAGO_BOOKING_APPLICATION_FEE_PERCENT=8

# Stripe (Connect + Checkout de assinatura quando PLATFORM_SUBSCRIPTION_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# E-mail (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Banco (Docker local: docker-compose mapeia host 5433 → 5432 no container)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/reservaestudio?schema=public
